{
  "manifest_version": 3,
  "name": "LeetCode → GitHub Auto Sync",
  "version": "1.0.0",
  "description": "Automatically push your accepted LeetCode solutions to a GitHub repository. 100% client-side — your credentials never leave your browser.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webRequest",
    "cookies",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LeetCode → GitHub Auto Sync"
  },
  "options_ui": {
    "page": "dashboard.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
