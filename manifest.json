{
  "manifest_version": 3,
  "name": "LeetCode → GitHub Auto Sync",
  "version": "1.0.0",
  "description": "Automatically push your accepted LeetCode solutions to a GitHub repository. 100% client-side — your credentials never leave your browser.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webRequest",
    "cookies",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "https://github.com/*",
    "https://codeforces.com/*",
    "https://*.codeforces.com/*",
    "https://www.hackerrank.com/*",
    "https://*.geeksforgeeks.org/*",
    "https://practiceapi.geeksforgeeks.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://codeforces.com/contest/*/problem/*",
        "https://codeforces.com/problemset/problem/*/*",
        "https://codeforces.com/problemset/problem/*"
      ],
      "js": ["content_cf.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.geeksforgeeks.org/*"],
      "js": ["content_gfg.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.geeksforgeeks.org/*"],
      "js": ["content_gfg_main.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LeetCode → GitHub Auto Sync"
  },
  "options_ui": {
    "page": "dashboard.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
